<?xml version="1.0" encoding="utf-8" ?>
<component name="HelloScene" extends="Scene">
  <children>
    <!-- Backgrounds first -->
    <Poster id="backgroundPoster" translation="[0, 0]" width="1920" height="1080" loadDisplayMode="scaleToZoom" opacity="0.0" />
    <Poster id="backgroundPosterNext" translation="[0, 0]" width="1920" height="1080" loadDisplayMode="scaleToZoom" opacity="0.0" />
    <Rectangle id="backgroundOverlay" width="1920" height="1080" color="0x000000ff" opacity="0.3" />
    <Rectangle id="headerBar" width="1920" height="80" color="0x2d2d5cff" opacity="0.0" />

    <!-- Static UI Elements -->
    <Label id="monthLabel" text="Loading..." translation="[40, 20]" font="font:MediumBoldSystemFont" color="0xffffffff" />
    <Label id="todayLabel" text="" translation="[40, 70]" font="font:SmallSystemFont" color="0xddddddff" />
    
    <Group id="weatherGroup" translation="[1280, 20]">
      <Label id="tempLabel" text="--°" font="font:MediumBoldSystemFont" color="0xffffffff" width="600" horizAlign="right" />
      <Label id="conditionLabel" text="Loading weather..." translation="[0, 35]" font="font:SmallSystemFont" color="0xccccccff" width="600" horizAlign="right" wrap="true" />
    </Group>
    
    <Group id="calendarGroup" translation="[20, 110]" scale="[0.85, 0.85]">
      <Label text="Sun" translation="[0, 0]" font="font:SmallBoldSystemFont" color="0xffaa00ff" width="230" height="40" />
      <Label text="Mon" translation="[240, 0]" font="font:SmallBoldSystemFont" color="0xffffffff" width="230" height="40" />
      <Label text="Tue" translation="[480, 0]" font="font:SmallBoldSystemFont" color="0xffffffff" width="230" height="40" />
      <Label text="Wed" translation="[720, 0]" font="font:SmallBoldSystemFont" color="0xffffffff" width="230" height="40" />
      <Label text="Thu" translation="[960, 0]" font="font:SmallBoldSystemFont" color="0xffffffff" width="230" height="40" />
      <Label text="Fri" translation="[1200, 0]" font="font:SmallBoldSystemFont" color="0xffffffff" width="230" height="40" />
      <Label text="Sat" translation="[1440, 0]" font="font:SmallBoldSystemFont" color="0xffaa00ff" width="230" height="40" />
      <Group id="daysGroup" translation="[0, 50]" />
    </Group>

    <!-- Overlay last -->
    <Group id="loginOverlay" visible="false">
      <Rectangle width="1920" height="1080" color="0x000000dd" />
      <Group translation="[660, 300]">
        <Rectangle width="600" height="400" color="0x2d2d5cff" />
        <Label id="loginTitle" text="Login Required" translation="[0, 40]" width="600" horizAlign="center" font="font:MediumBoldSystemFont" />
        <Label id="loginUrl" text="" translation="[0, 120]" width="600" horizAlign="center" font="font:MediumSystemFont" />
        <Label id="loginCode" text="XXXX-XXXX" translation="[0, 200]" width="600" horizAlign="center" font="font:MediumBoldSystemFont" color="0x00ff00ff" />
        <Label text="Press BACK to cancel" translation="[0, 320]" width="600" horizAlign="center" font="font:SmallSystemFont" color="0xaaaaaaff" />
      </Group>
    </Group>

    <!-- Animations -->
    <Animation id="fadeTransition" duration="2.0" repeat="false" easeFunction="linear">
        <FloatFieldInterpolator id="fadeAway" fieldToInterp="backgroundPoster.opacity" key="[0.0, 1.0]" keyValue="[0.8, 0.0]" />
        <FloatFieldInterpolator id="fadeIn" fieldToInterp="backgroundPosterNext.opacity" key="[0.0, 1.0]" keyValue="[0.0, 0.8]" />
    </Animation>
  </children>
  
  <script type="text/brightscript" uri="pkg:/source/config.brs" />
  <script type="text/brightscript" uri="pkg:/components/HelloScene.brs" />
</component>
